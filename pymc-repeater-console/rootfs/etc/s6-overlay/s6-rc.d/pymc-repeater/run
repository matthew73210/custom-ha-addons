#!/usr/bin/with-contenv bashio
set -euo pipefail

CONFIG_PATH="/etc/pymc_repeater/config.yaml"
UPSTREAM_METADATA_PATH="/usr/share/pymc-repeater-console/upstream-build-info.json"
PYTHON_BIN="/opt/venv/bin/python3"
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8001"
DIRECT_HOST="127.0.0.1"
DIRECT_PORT="8000"
INGRESS_HOST="127.0.0.1"
INGRESS_PORT="8080"
READY_TIMEOUT="${PYMC_READY_TIMEOUT:-60}"
LOG_LEVEL="$("${PYTHON_BIN}" - <<'PY'
import pathlib

import yaml

config_path = pathlib.Path("/etc/pymc_repeater/config.yaml")
try:
    with config_path.open("r", encoding="utf-8") as handle:
        config = yaml.safe_load(handle) or {}
except Exception:
    config = {}

level = str((config.get("logging") or {}).get("level", "INFO")).upper()
if level not in {"DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"}:
    level = "INFO"
print(level)
PY
)"
DEBUG_LOG="false"
if [ "${LOG_LEVEL}" = "DEBUG" ]; then
  DEBUG_LOG="true"
fi

s6-svc -O /run/service/pymc-repeater 2>/dev/null || true

log_redacted_config() {
  bashio::log.info "Persisted ${CONFIG_PATH} (secrets redacted):"
  "${PYTHON_BIN}" - <<'PY' | while IFS= read -r line; do bashio::log.info "config | ${line}"; done
import pathlib

import yaml

SENSITIVE_KEYS = {
    "admin_password",
    "api_key",
    "api_token",
    "guest_password",
    "identity_key",
    "jwt_secret",
    "password",
    "private_key",
    "token",
}


def redact(value):
    if isinstance(value, dict):
        redacted = {}
        for key, item in value.items():
            if str(key).lower() in SENSITIVE_KEYS:
                redacted[key] = "<redacted>"
            else:
                redacted[key] = redact(item)
        return redacted
    if isinstance(value, list):
        return [redact(item) for item in value]
    return value


config_path = pathlib.Path("/etc/pymc_repeater/config.yaml")
with config_path.open("r", encoding="utf-8") as handle:
    config = yaml.safe_load(handle) or {}

print(yaml.safe_dump(redact(config), default_flow_style=False, sort_keys=False).rstrip())
PY
}

log_storage_diagnostics() {
  "${PYTHON_BIN}" - <<'PY' | while IFS= read -r line; do bashio::log.info "storage | ${line}"; done
import pathlib
import sqlite3

import yaml

config_path = pathlib.Path("/etc/pymc_repeater/config.yaml")

try:
    with config_path.open("r", encoding="utf-8") as handle:
        config = yaml.safe_load(handle) or {}
except Exception as exc:
    print(f"unable to read config: {exc}")
    raise SystemExit(0)

storage_dir = pathlib.Path(config.get("storage", {}).get("storage_dir", "/config/pymc-repeater"))
identity_file = pathlib.Path(config.get("repeater", {}).get("identity_file", "/config/pymc-repeater/identity.key"))
db_path = storage_dir / "repeater.db"
rrd_path = storage_dir / "metrics.rrd"

def describe(label, path):
    try:
        real = path.resolve(strict=False)
    except Exception:
        real = path
    if path.exists():
        try:
            size = path.stat().st_size
        except Exception:
            size = "unknown"
        print(f"{label}: {path} -> {real} exists size={size}")
    else:
        print(f"{label}: {path} -> {real} missing")

describe("pyMC config path", config_path)
describe("storage_dir", storage_dir)
describe("identity_file", identity_file)
describe("repeater.db", db_path)
describe("metrics.rrd", rrd_path)

if db_path.exists():
    try:
        with sqlite3.connect(str(db_path)) as conn:
            tables = [
                "packets",
                "adverts",
                "noise_floor",
                "crc_errors",
                "room_messages",
                "companion_contacts",
                "companion_messages",
                "api_tokens",
            ]
            counts = []
            for table in tables:
                exists = conn.execute(
                    "SELECT 1 FROM sqlite_master WHERE type='table' AND name=?",
                    (table,),
                ).fetchone()
                if exists:
                    count = conn.execute(f"SELECT COUNT(*) FROM {table}").fetchone()[0]
                    counts.append(f"{table}={count}")
            if counts:
                print("sqlite table counts: " + ", ".join(counts))
            else:
                print("sqlite table counts: no known pyMC tables found")
    except Exception as exc:
        print(f"sqlite table counts unavailable: {exc}")
PY
}

log_listeners() {
  bashio::log.info "Listening TCP sockets:"
  if command -v ss >/dev/null 2>&1; then
    ss -ltnp 2>&1 | while IFS= read -r line; do bashio::log.info "ss | ${line}"; done
  elif command -v netstat >/dev/null 2>&1; then
    netstat -ltnp 2>&1 | while IFS= read -r line; do bashio::log.info "netstat | ${line}"; done
  else
    bashio::log.warning "Neither ss nor netstat is available for listener diagnostics."
  fi
}

curl_probe_summary() {
  local url="$1"
  local output

  if ! command -v curl >/dev/null 2>&1; then
    echo "curl unavailable"
    return 1
  fi

  output="$(curl -sS -L --max-time 3 -o /dev/null -w '%{http_code} %{size_download} %{content_type}' "${url}" 2>&1)" || {
    echo "${output}"
    return 1
  }
  echo "${output}"
}

compare_endpoint_probe() {
  local path="$1"
  local direct_url="http://${DIRECT_HOST}:${DIRECT_PORT}${path}"
  local ingress_url="http://${INGRESS_HOST}:${INGRESS_PORT}${path}"
  local direct_output
  local ingress_output

  direct_output="$(curl_probe_summary "${direct_url}")" || direct_output="ERR ${direct_output}"
  ingress_output="$(curl_probe_summary "${ingress_url}")" || ingress_output="ERR ${ingress_output}"

  if [ "${direct_output}" = "${ingress_output}" ]; then
    bashio::log.info "Endpoint probe ${path}: direct=${direct_output}; ingress matches"
  else
    bashio::log.warning "Endpoint probe ${path}: direct=${direct_output}; ingress=${ingress_output}"
  fi
}

log_endpoint_diagnostics() {
  bashio::log.info "Comparing direct wrapper and ingress API routes used by Console graphs/history."
  compare_endpoint_probe "/api/stats?probe=query"
  compare_endpoint_probe "/api/recent_packets?limit=5"
  compare_endpoint_probe "/api/filtered_packets?limit=5"
  compare_endpoint_probe "/api/packet_stats?hours=24"
  compare_endpoint_probe "/api/packet_type_graph_data?hours=24&resolution=average&types=all"
  compare_endpoint_probe "/api/metrics_graph_data?hours=24&resolution=average&metrics=rx_count,tx_count"
  compare_endpoint_probe "/api/rrd_data?start_time=0&end_time=0&resolution=average"
  compare_endpoint_probe "/api/noise_floor_history?hours=24"
  compare_endpoint_probe "/api/crc_error_history?hours=24"
  compare_endpoint_probe "/api/adverts_by_contact_type?limit=5&hours=24"
  compare_endpoint_probe "/api/db_stats"
  compare_endpoint_probe "/api/analytics/topology"
  compare_endpoint_probe "/api/analytics/bucketed_stats?preset=1h"
}

notify_ready() {
  if [ -e "/proc/$$/fd/3" ]; then
    printf '\n' >&3
  fi
}

http_probe() {
  "${PYTHON_BIN}" - "$1" <<'PY'
import sys
import urllib.error
import urllib.request

url = sys.argv[1]
request = urllib.request.Request(url, method="GET")
try:
    with urllib.request.urlopen(request, timeout=2) as response:
        status = response.getcode()
except urllib.error.HTTPError as exc:
    status = exc.code
except Exception as exc:
    print(exc)
    sys.exit(1)

if status < 500:
    print(f"HTTP {status}")
else:
    print(f"HTTP {status}")
    sys.exit(1)
PY
}

runtime_support_sanity() {
  (
    cd /
    "${PYTHON_BIN}" - <<'PY'
import inspect

import repeater.config as c
from pymc_core.hardware.tcp_radio import TCPLoRaRadio

src = inspect.getsource(c)
assert "pymc_tcp" in src, "Installed pyMC_Repeater does not contain pymc_tcp support"
assert "pymc_usb" in src, "Installed pyMC_Repeater does not contain pymc_usb support"
print(f"pymc_tcp and pymc_usb support present in installed repeater.config: {c.__file__}")
print(f"TCPLoRaRadio import OK: {TCPLoRaRadio}")
PY
  )
}

log_upstream_metadata() {
  if [ ! -f "${UPSTREAM_METADATA_PATH}" ]; then
    bashio::log.warning "Upstream build metadata not found at ${UPSTREAM_METADATA_PATH}."
    return 0
  fi

  "${PYTHON_BIN}" - "${UPSTREAM_METADATA_PATH}" <<'PY' | while IFS= read -r line; do bashio::log.info "upstream | ${line}"; done
import json
import pathlib
import sys

metadata_path = pathlib.Path(sys.argv[1])
try:
    metadata = json.loads(metadata_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"unable to read {metadata_path}: {exc}")
    raise SystemExit(0)

repeater = metadata.get("pymc_repeater") or {}
core = metadata.get("pymc_core") or {}
console = metadata.get("pymc_console_dist") or {}

print(
    "pyMC Repeater requested_ref="
    f"{repeater.get('requested_ref', 'unknown')} "
    f"resolved_sha={repeater.get('resolved_sha', 'unknown')}"
)
print(
    "pyMC_core requested_ref="
    f"{core.get('requested_ref', 'unknown')} "
    f"resolved_sha={core.get('resolved_sha', 'unknown')}"
)
print(
    "pyMC Console dist requested_ref="
    f"{console.get('requested_ref', 'unknown')} "
    f"resolved_sha={console.get('resolved_sha', 'unknown')} "
    f"version={console.get('version') or 'unknown'}"
)
PY
}

wait_for_probe() {
  local label="$1"
  local command_name="$2"
  local deadline=$((SECONDS + READY_TIMEOUT))
  local output=""

  shift 2
  while [ "${SECONDS}" -lt "${deadline}" ]; do
    if ! kill -0 "${BACKEND_PID}" 2>/dev/null; then
      set +e
      wait "${BACKEND_PID}"
      local status=$?
      set -e
      log_redacted_config
      log_storage_diagnostics
      bashio::log.fatal "pyMC Repeater exited before startup completed with status ${status}."
      halt_addon "${status}"
    fi

    if output="$("${command_name}" "$@" 2>&1)"; then
      bashio::log.info "${label}: ${output}"
      return 0
    fi
    sleep 1
  done

  bashio::log.fatal "Timed out waiting for ${label}: ${output}"
  log_redacted_config
  log_storage_diagnostics
  kill -TERM "${BACKEND_PID}" 2>/dev/null || true
  wait "${BACKEND_PID}" 2>/dev/null || true
  halt_addon 1
}

stop_backend() {
  bashio::log.info "Stopping pyMC Repeater backend."
  kill -TERM "${BACKEND_PID}" 2>/dev/null || true
  wait "${BACKEND_PID}" 2>/dev/null || true
}

halt_addon() {
  local status="$1"

  if [ -w /run/s6-linux-init-container-results/exitcode ]; then
    printf '%s' "${status}" > /run/s6-linux-init-container-results/exitcode
  fi

  if [ "${status}" = "0" ]; then
    bashio::log.info "Stopping add-on because pyMC Repeater is no longer running."
  else
    bashio::log.fatal "pyMC Repeater exited fatally; stopping add-on"
  fi

  s6-svc -d /run/service/pymc-repeater-ingress 2>/dev/null || true
  exit "${status}"
}

bashio::log.info "Selected internal backend entrypoint: http://${BACKEND_HOST}:${BACKEND_PORT}"
bashio::log.info "Selected direct wrapper entrypoint: http://${DIRECT_HOST}:${DIRECT_PORT}"
bashio::log.info "Selected ingress entrypoint: http://0.0.0.0:${INGRESS_PORT}"
log_upstream_metadata
if [ "${DEBUG_LOG}" = "true" ]; then
  log_redacted_config
fi
log_storage_diagnostics
runtime_support_sanity | while IFS= read -r line; do bashio::log.info "runtime | ${line}"; done

bashio::log.info "Starting pyMC Repeater backend on port ${BACKEND_PORT}."
"${PYTHON_BIN}" -m repeater.main --config "${CONFIG_PATH}" --log-level "${LOG_LEVEL}" &
BACKEND_PID="$!"
trap 'stop_backend; exit 0' INT TERM

wait_for_probe "Internal backend HTTP" http_probe "http://${BACKEND_HOST}:${BACKEND_PORT}/"
wait_for_probe "Internal backend API" http_probe "http://${BACKEND_HOST}:${BACKEND_PORT}/api/stats"
bashio::log.info "pyMC Repeater backend is accepting HTTP"

wait_for_probe "Direct wrapper HTTP" http_probe "http://${DIRECT_HOST}:${DIRECT_PORT}/"
wait_for_probe "Direct wrapper API" http_probe "http://${DIRECT_HOST}:${DIRECT_PORT}/api/stats"
bashio::log.info "Direct wrapper entrypoint is accepting HTTP"

wait_for_probe "Ingress HTTP" http_probe "http://${INGRESS_HOST}:${INGRESS_PORT}/"
bashio::log.info "Ingress entrypoint is accepting HTTP"

if [ "${DEBUG_LOG}" = "true" ]; then
  log_endpoint_diagnostics
  log_listeners
fi
bashio::log.info "Add-on startup complete"
notify_ready

set +e
wait "${BACKEND_PID}"
BACKEND_STATUS="$?"
set -e

if [ "${BACKEND_STATUS}" -eq 0 ]; then
  bashio::log.info "pyMC Repeater backend exited with status 0."
else
  bashio::log.fatal "pyMC Repeater backend exited with status ${BACKEND_STATUS}."
fi

halt_addon "${BACKEND_STATUS}"
